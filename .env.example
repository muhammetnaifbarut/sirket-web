# ─────────────────────────────────────────────────────────────────
# kooza — environment template
# Production için bu dosyayı kopyalayıp gerçek değerleri girin.
# Vercel'de "Environment Variables" sekmesinden ekleyin (.env'i commit ETMEYIN).
# ─────────────────────────────────────────────────────────────────

# ─── DATABASE (Supabase / Neon / RDS) ────────────────────────────
# Supabase: Settings → Database → Connection string → URI (port 6543, pooler önerilir)
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migration için direkt bağlantı (port 5432, pooler dışı)
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── NEXTAUTH (admin login) ──────────────────────────────────────
# 32+ karakter rastgele string. Üretmek için: `openssl rand -base64 32`
NEXTAUTH_SECRET="UPRODUCTION_DEGISTIR_min_32_karakter_rastgele_string"
# Production domain (https zorunlu)
NEXTAUTH_URL="https://kooza.com.tr"

# ─── PUBLIC URL (sitemap + OG image absolute URL'ler için) ──────
NEXT_PUBLIC_APP_URL="https://kooza.com.tr"
NEXT_PUBLIC_SITE_NAME="kooza"

# ─── EMAIL (Resend — form bildirimleri & şifre sıfırlama) ───────
# https://resend.com/api-keys
RESEND_API_KEY="re_xxx"
EMAIL_FROM="kooza <noreply@kooza.com.tr>"
EMAIL_TO_ADMIN="info@kooza.com.tr"

# ─── UPLOADS ─────────────────────────────────────────────────────
# Vercel'de filesystem yazılamaz — Supabase Storage veya UploadThing kullanın
# Supabase Storage bucket adı:
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="kooza-uploads"

# ─── WHATSAPP ────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="+905xxxxxxxxx"

# ─── ANALYTICS (opsiyonel) ───────────────────────────────────────
NEXT_PUBLIC_GA_ID=""

# ─── AI (chatbot + blog üretimi) ─────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ─── CRON (otomatik blog) ────────────────────────────────────────
# Vercel Cron'dan çağrı için — rastgele 32 char string
CRON_SECRET="UPRODUCTION_CRON_SECRET_32_CHAR"

# ─── NODE ENV (Vercel otomatik set eder, manuel girmeyin) ────────
# NODE_ENV="production"
